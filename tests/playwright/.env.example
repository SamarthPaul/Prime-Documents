# Copy to `.env` and fill. `.env` is gitignored — never commit secrets.
# In CI, these come from GitHub Actions secrets, not from a file.

BASE_URL=https://stgprime-rural.dhwaniris.in

# Per-role passwords (used by global-setup to mint session storageState files)
UAT_SM_PASSWORD=UatPr1me!2026Strong
UAT_CTI_PASSWORD=UatPr1me!2026Strong
UAT_CTP_PASSWORD=UatPr1me!2026Strong
UAT_FA_PASSWORD=UatPr1me!2026Strong
UAT_SELCO_PASSWORD=UatPr1me!2026Strong
UAT_DESIGNER_PASSWORD=UatPr1me!2026Strong

# Administrator API token (used by api fixture for setup/teardown of [UAT] records)
# Generate from /app/user/Administrator → API Access. Rotate before go-live.
ADMIN_API_KEY=
ADMIN_API_SECRET=
